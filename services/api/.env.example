# QuantifyU Backend Environment Variables
# 复制为 .env 并填入真实值

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# API
API_ENV=development
API_CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# 加密（生成命令: python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"）
ENCRYPTION_MASTER_KEY=your-base64-encoded-32-byte-key
ENCRYPTION_KEY_VERSION=1

# AI模型
MODEL_DEVICE=cpu
VIT_FBP_MODEL_PATH=./app/ai/models/vit_fbp.pth
